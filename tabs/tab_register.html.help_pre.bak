      <div id="tab-register" class="tab-view active">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; padding:8px 0; border-bottom:1px solid #e5e7eb;">
          <span style="font-size:14px; color:#6b7280;">현재 메뉴</span>
          <button onclick="showHelp('register')"
                  style="background:#f3f4f6; border:1px solid #d1d5db; border-radius:20px; padding:4px 12px; font-size:13px; cursor:pointer; color:#374151;"
                  title="이 화면 사용법 보기">
            ❓ 도움말
          </button>
        </div>


        <!-- 내 입찰 현황 동기화 -->
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px">
          <button class="btn btn-outline" id="sync-bids-btn" onclick="syncMyBids()">내 입찰 현황 동기화 🔄</button>
          <span id="sync-bids-status" style="font-size:12px; color:var(--text3)">동기화 안 됨</span>
        </div>

        <!-- 상품 추가 폼 -->
        <div class="card">
          <div class="card-title"><span class="icon">📥</span> 상품 추가</div>
          <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end">
            <div>
              <div style="font-size:11px; color:var(--text3); margin-bottom:4px">모델번호/품번 *</div>
              <input type="text" class="form-input" id="q-model" placeholder="IX7694" style="width:160px" onkeydown="if(event.key==='Enter')queueAdd()">
            </div>
            <div>
              <div style="font-size:11px; color:var(--text3); margin-bottom:4px">카테고리</div>
              <select class="form-select" id="q-category" style="width:130px">
                <option value="">자동 판별</option>
                <option value="가방">가방 (8%)</option>
                <option value="신발">신발 (13%)</option>
                <option value="의류">의류 (13%)</option>
              </select>
            </div>
            <div id="q-cny-wrap">
              <div style="font-size:11px; color:var(--text3); margin-bottom:4px">중국가 (CNY) *</div>
              <input type="number" class="form-input" id="q-cny" placeholder="220" style="width:100px" onkeydown="if(event.key==='Enter')queueAdd()">
            </div>
            <div>
              <div style="font-size:11px; color:var(--text3); margin-bottom:4px">배송비</div>
              <input type="number" class="form-input" id="q-ship" value="8000" style="width:90px">
            </div>
            <div>
              <div style="font-size:11px; color:var(--text3); margin-bottom:4px">수량</div>
              <input type="number" class="form-input" id="q-qty" value="1" min="1" style="width:60px">
            </div>
            <div>
              <div style="font-size:11px; color:var(--text3); margin-bottom:4px">만료일</div>
              <select class="form-select" id="q-bid-days" style="width:80px">
                <option value="30" selected>30일</option>
                <option value="60">60일</option>
                <option value="90">90일</option>
              </select>
            </div>
            <div>
              <div style="font-size:11px; color:var(--text3); margin-bottom:4px">입찰 전략</div>
              <select class="form-select" id="q-bid-strategy" style="width:140px">
                <option value="10">마진 10%</option>
                <option value="15">마진 15%</option>
                <option value="20">마진 20%</option>
                <option value="undercut" selected>언더컷 -1,000원</option>
                <option value="custom">직접 입력</option>
              </select>
            </div>
            <button class="btn btn-primary" id="q-add-btn" onclick="queueAdd()" style="height:38px">+ 큐에 추가</button>
            <button class="btn btn-outline" onclick="marketCheck()" style="height:38px;border-color:#6366f1;color:#6366f1" title="得物 원가 기준 시장 분류 사전 체크">시장 체크</button>
          </div>

          <!-- 시장 체크 결과 -->
          <div id="market-check-result" style="display:none; margin-top:12px; padding:12px 16px; border-radius:8px; border:1px solid var(--border); font-size:13px"></div>

          <!-- 사이즈별 가격 입력 (항상 표시) -->
          <div id="q-shoe-area" style="margin-top:16px; padding:16px; background:var(--bg); border-radius:8px; border:1px solid var(--border)">
            <div style="display:flex; align-items:center; gap:16px; margin-bottom:12px">
              <strong style="font-size:13px">사이즈별 가격 (mm)</strong>
              <label style="font-size:12px; display:flex; align-items:center; gap:4px; cursor:pointer">
                <input type="checkbox" id="q-same-price" onchange="qToggleSamePrice()"> 전사이즈 동일가
              </label>
            </div>
            <!-- 동일가 모드 -->
            <div id="q-same-price-area" style="display:none; margin-bottom:12px">
              <div style="display:flex; gap:8px; align-items:center; font-size:13px">
                <span>중국가(CNY):</span>
                <input type="number" class="form-input" id="q-same-cny" placeholder="314" style="width:90px; height:30px; font-size:12px">
                <span>사이즈 범위:</span>
                <input type="text" class="form-input" id="q-same-from" placeholder="250" style="width:60px; height:30px; font-size:12px">
                <span>~</span>
                <input type="text" class="form-input" id="q-same-to" placeholder="280" style="width:60px; height:30px; font-size:12px">
              </div>
              <div style="font-size:11px; color:var(--text3); margin-top:4px">
                범위 입력 예: 215~255 → 5mm 간격 자동 생성 | 콤마 구분: S,M,L,XL
              </div>
            </div>
            <!-- 개별 사이즈 테이블 -->
            <div id="q-sizes-table-area">
              <table style="width:auto; font-size:12px">
                <thead><tr><th style="width:80px">사이즈(mm)</th><th style="width:100px">중국가(CNY)</th><th style="width:40px"></th></tr></thead>
                <tbody id="q-sizes-tbody"></tbody>
              </table>
              <button class="btn btn-outline btn-sm" onclick="qAddSizeRow()" style="margin-top:4px; font-size:11px">+ 사이즈 행 추가</button>
            </div>
          </div>
        </div>

        <!-- 큐 테이블 -->
        <div class="card">
          <div class="card-title" style="justify-content:space-between">
            <span><span class="icon">📋</span> 상품 큐 (<span id="q-count">0</span>건)</span>
            <div style="display:flex; gap:8px; align-items:center">
              <button class="btn btn-outline btn-sm" onclick="queueDownloadExcel()">큐 다운로드</button>
              <button class="btn btn-outline btn-sm" onclick="document.getElementById('q-upload-file').click()">큐 업로드</button>
              <button class="btn btn-outline btn-sm" onclick="document.getElementById('q-restore-file').click()" style="color:var(--blue)">백업 복원</button>
              <button class="btn btn-outline btn-sm" onclick="queueDownloadTemplate()" style="color:var(--text2)">양식 다운로드</button>
              <input type="file" id="q-upload-file" accept=".csv,.xlsx,.xls" style="display:none" onchange="queueUploadExcel(this)">
              <input type="file" id="q-restore-file" accept=".csv,.xlsx,.xls" style="display:none" onchange="queueRestoreBackup(this)">
              <button class="btn btn-outline btn-sm" onclick="queueClear()">전체 삭제</button>
              <button class="btn btn-primary btn-sm" id="q-exec-btn" onclick="queueExecute()">일괄 실행 (KREAM 검색 + 마진 계산)</button>
              <label style="font-size:11px; display:flex; align-items:center; gap:4px; cursor:pointer; color:var(--text2)">
                <input type="checkbox" id="q-auto-exec-toggle" onchange="toggleAutoExec()"> 자동 실행
              </label>
            </div>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th style="width:40px">#</th>
                  <th>모델번호</th>
                  <th>카테고리</th>
                  <th>사이즈</th>
                  <th>중국가(CNY)</th>
                  <th>배송비</th>
                  <th>수량</th>
                  <th>만료일</th>
                  <th>상태</th>
                  <th style="width:110px">액션</th>
                </tr>
              </thead>
              <tbody id="q-tbody">
                <tr><td colspan="10" class="text-muted">큐가 비어있습니다. 위에서 상품을 추가하세요.</td></tr>
              </tbody>
            </table>
          </div>
          <div class="log-area" id="q-log" style="display:none; margin-top:12px; max-height:200px"></div>
        </div>

        <!-- 결과 테이블 -->
        <div class="card" id="q-result-card" style="display:none">
          <div class="card-title" style="justify-content:space-between">
            <span><span class="icon">📊</span> 일괄 실행 결과</span>
            <div style="display:flex; gap:8px; align-items:center">
              <label style="font-size:12px; display:flex; align-items:center; gap:4px">
                기본 전략:
                <select class="form-select" id="q-default-margin" style="height:30px; font-size:12px; width:130px" onchange="queueBuildResults()">
                  <option value="10">마진 10%</option>
                  <option value="15">마진 15%</option>
                  <option value="20">마진 20%</option>
                  <option value="undercut" selected>언더컷 -1,000원</option>
                </select>
              </label>

              <button class="btn btn-outline btn-sm" onclick="queueExportExcel()">CSV 다운로드</button>
              <button class="btn btn-outline btn-sm" onclick="qDeleteAllResults()" style="color:var(--danger);border-color:var(--danger)">전체 결과 삭제</button>
            </div>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th style="width:36px"><input type="checkbox" id="q-res-all" onchange="queueToggleAll(this)"></th>
                  <th style="cursor:pointer;user-select:none" onclick="qToggleSortModel()" id="q-res-th-model">모델번호</th>
                  <th>상품명</th>
                  <th>카테고리</th>
                  <th>원가</th>
                  <th>즉시구매가</th>
                  <th style="background:var(--blue-light); color:var(--blue)">내 입찰가</th>
                  <th style="background:var(--accent-light)">입찰 예정가</th>
                  <th>전략</th>
                  <th>수량</th>
                  <th>예상 마진</th>
                  <th>고시정보</th>
                  <th style="width:100px">액션</th>
                </tr>
              </thead>
              <tbody id="q-result-tbody"></tbody>
            </table>
          </div>
          <!-- 상세 분석 패널 (토글) -->
          <div id="q-detail-panel" style="display:none"></div>
          <div class="mt-16" style="display:flex; gap:8px; align-items:center; flex-wrap:wrap">
            <button class="btn btn-outline btn-lg" onclick="queueDownloadBackupExcel()">엑셀 백업 다운로드</button>
            <button class="btn btn-outline btn-lg" onclick="document.getElementById('q-backup-upload-file').click()">엑셀 백업 업로드</button>
            <input type="file" id="q-backup-upload-file" accept=".csv" style="display:none" onchange="queueUploadBackupExcel(this)">
            <button class="btn btn-outline btn-lg" onclick="queueConfirmExcel()">엑셀 생성 (수동 업로드)</button>
            <button class="btn btn-primary btn-lg" id="q-bulk-upload-btn" onclick="queueBulkExcelUpload()">대량입찰 엑셀 업로드</button>
            <button class="btn btn-primary btn-lg" id="q-auto-bid-btn" onclick="queueConfirmAutoBid()">자동 입찰 (Playwright)</button>
            <button class="btn btn-outline btn-lg" onclick="qRemoveLowMargin()" style="color:var(--danger);border-color:var(--danger)">마진 5,000원 미만 제거</button>
            <span id="q-result-summary" class="text-muted" style="font-size:12px"></span>
          </div>
          <!-- 자동입찰 제어 버튼 (진행 중에만 표시) -->
          <div id="q-auto-controls" style="display:none; margin-top:8px; display:none; gap:8px; align-items:center">
            <button class="btn btn-outline" id="q-pause-btn" onclick="autoBidPause()" style="border-color:var(--warning);color:var(--warning)">일시정지</button>
            <button class="btn btn-outline" id="q-resume-btn" onclick="autoBidResume()" style="display:none; border-color:var(--accent);color:var(--accent)">이어서 진행</button>
            <button class="btn btn-outline" id="q-stop-btn" onclick="autoBidStop()" style="display:none; border-color:var(--danger);color:var(--danger)">중단</button>
            <span id="q-auto-status" class="text-muted" style="font-size:12px"></span>
          </div>
          <div class="log-area" id="q-auto-log" style="display:none; margin-top:12px; max-height:250px"></div>
        </div>
      </div>

      <!-- 상세 편집 모달 -->
      <div id="q-modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:1000; justify-content:center; align-items:center">
        <div style="background:#fff; border-radius:12px; width:560px; max-height:85vh; overflow-y:auto; padding:24px; position:relative">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px">
            <h3 id="q-modal-title" style="font-size:16px; font-weight:700"></h3>
            <button onclick="qModalClose()" style="background:none; border:none; font-size:20px; cursor:pointer; color:var(--text3)">&times;</button>
          </div>
          <div id="q-modal-body"></div>
          <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:16px; border-top:1px solid var(--border); padding-top:16px">
            <button class="btn btn-outline" onclick="qModalClose()">취소</button>
            <button class="btn btn-primary" onclick="qModalSave()">저장</button>
          </div>
        </div>
      </div>

      <!-- ═══ 탭2: 마진 계산기 ═══ -->