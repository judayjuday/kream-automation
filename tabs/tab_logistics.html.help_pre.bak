      <div id="tab-logistics" class="tab-view">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; padding:8px 0; border-bottom:1px solid #e5e7eb;">
          <span style="font-size:14px; color:#6b7280;">현재 메뉴</span>
          <button onclick="showHelp('logistics')"
                  style="background:#f3f4f6; border:1px solid #d1d5db; border-radius:20px; padding:4px 12px; font-size:13px; cursor:pointer; color:#374151;"
                  title="이 화면 사용법 보기">
            ❓ 도움말
          </button>
        </div>

        <!-- 허브넷 PDF 자동 다운로드 (Step 9) -->
        <div class="card" style="margin-bottom:16px">
          <div class="card-title" style="display:flex; justify-content:space-between; align-items:center">
            <span><span class="icon">📦</span> 허브넷 PDF 자동 다운로드</span>
            <button class="btn btn-outline" onclick="hubnetRefresh()" style="font-size:12px; padding:4px 12px">🔄 새로고침</button>
          </div>

          <!-- 상태 영역 -->
          <div style="display:flex; flex-wrap:wrap; gap:24px; align-items:center; margin:8px 0 12px; padding:12px; background:var(--bg2); border-radius:8px; font-size:13px">
            <span>
              세션: <span id="hubnet-session-indicator">⏳</span>
              <span id="hubnet-session-detail" class="text-muted">확인 중...</span>
            </span>
            <span style="display:flex; align-items:center; gap:8px">
              자동 다운로드:
              <label style="display:inline-flex; align-items:center; gap:6px; cursor:pointer">
                <input type="checkbox" id="hubnet-auto-toggle" disabled onchange="hubnetOnAutoToggle(this)">
                <span id="hubnet-auto-label" style="font-weight:600">OFF</span>
              </label>
            </span>
          </div>

          <!-- 액션 버튼 -->
          <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px">
            <button class="btn btn-outline" id="hubnet-relogin-btn" onclick="hubnetOnRelogin()" style="font-size:12px">수동 재로그인</button>
            <button class="btn btn-primary" id="hubnet-sync-btn" onclick="hubnetOnOpenSyncModal()" style="font-size:12px">지금 동기화</button>
          </div>

          <!-- 오늘 통계 -->
          <div style="margin-bottom:12px">
            <div style="font-size:12px; color:var(--text3); margin-bottom:6px">📊 오늘 통계</div>
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:8px">
              <div style="background:var(--bg2); padding:8px 10px; border-radius:6px; font-size:12px">성공: <span id="hubnet-stat-success" style="font-weight:600">-</span>건</div>
              <div style="background:var(--bg2); padding:8px 10px; border-radius:6px; font-size:12px">실패: <span id="hubnet-stat-failed" style="font-weight:600">-</span>건</div>
              <div style="background:var(--bg2); padding:8px 10px; border-radius:6px; font-size:12px">스킵: <span id="hubnet-stat-skipped" style="font-weight:600">-</span>건</div>
              <div style="background:var(--bg2); padding:8px 10px; border-radius:6px; font-size:12px">매칭실패: <span id="hubnet-stat-matching-failed" style="font-weight:600">-</span>건</div>
              <div style="background:var(--bg2); padding:8px 10px; border-radius:6px; font-size:12px">평균: <span id="hubnet-stat-avg-duration" style="font-weight:600">-</span></div>
            </div>
          </div>

          <!-- 이력 테이블 -->
          <div>
            <div style="font-size:12px; color:var(--text3); margin-bottom:6px">📋 최근 다운로드 이력 (최근 20건)</div>
            <div style="overflow-x:auto">
              <table>
                <thead>
                  <tr>
                    <th>시각</th>
                    <th>HBL</th>
                    <th>주문번호</th>
                    <th>상태</th>
                    <th>액션</th>
                  </tr>
                </thead>
                <tbody id="hubnet-log-tbody">
                  <tr><td colspan="5" class="text-muted">로딩 중...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- 동기화 날짜 입력 모달 -->
        <div id="hubnet-sync-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000; justify-content:center; align-items:center">
          <div style="background:var(--card); border-radius:12px; padding:24px; width:420px; max-width:90vw">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px">
              <h3 style="margin:0; font-size:16px">허브넷 데이터 동기화</h3>
              <button onclick="hubnetCloseSyncModal()" style="background:none; border:none; font-size:20px; cursor:pointer; color:var(--text3)">&times;</button>
            </div>
            <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:16px">
              <label style="display:flex; flex-direction:column; gap:4px; font-size:12px; color:var(--text3)">
                시작일
                <input type="date" id="hubnet-sync-start" class="form-input">
              </label>
              <label style="display:flex; flex-direction:column; gap:4px; font-size:12px; color:var(--text3)">
                종료일
                <input type="date" id="hubnet-sync-end" class="form-input">
              </label>
            </div>
            <div id="hubnet-sync-progress" style="display:none; margin-bottom:12px; padding:8px; background:var(--bg2); border-radius:6px; font-size:12px">
              <span id="hubnet-sync-progress-stage">동기화 중...</span>
            </div>
            <div style="display:flex; gap:8px; justify-content:flex-end">
              <button class="btn btn-outline" onclick="hubnetCloseSyncModal()" style="font-size:12px">취소</button>
              <button class="btn btn-primary" id="hubnet-sync-confirm-btn" onclick="hubnetOnSyncConfirm()" style="font-size:12px">동기화 시작</button>
            </div>
          </div>
        </div>

        <!-- 현황 카드 -->
        <div class="card">
          <div class="card-title"><span class="icon">🚚</span> 물류 현황</div>
          <div class="metrics" id="logistics-metrics">
            <div class="metric metric-blue">
              <div class="metric-label">발송 대기</div>
              <div class="metric-value" id="logi-pending-cnt">0건</div>
            </div>
            <div class="metric">
              <div class="metric-label">진행 중</div>
              <div class="metric-value" id="logi-progress-cnt">0건</div>
            </div>
            <div class="metric metric-green">
              <div class="metric-label">완료</div>
              <div class="metric-value" id="logi-done-cnt">0건</div>
            </div>
            <div class="metric">
              <div class="metric-label">이번 달 물류비</div>
              <div class="metric-value" id="logi-month-cost">0원</div>
            </div>
          </div>
        </div>

        <!-- 발송 대기 -->
        <div class="card" style="margin-top:16px">
          <div class="card-title" style="display:flex; justify-content:space-between; align-items:center">
            <span><span class="icon">📋</span> 발송 대기 (<span id="logi-wait-count">0</span>건)</span>
            <button class="btn btn-outline" onclick="loadPendingShipments()" style="font-size:12px; padding:4px 12px">새로고침</button>
          </div>
          <p class="text-muted" style="font-size:12px; margin-bottom:8px">KREAM 체결 건 중 발송 요청하지 않은 목록</p>
          <div style="overflow-x:auto">
            <table>
              <thead>
                <tr>
                  <th>주문번호</th>
                  <th>상품</th>
                  <th>사이즈</th>
                  <th>거래금액</th>
                  <th>거래일</th>
                  <th>작업</th>
                </tr>
              </thead>
              <tbody id="logi-pending-tbody">
                <tr><td colspan="6" class="text-muted">로딩 중...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 발송 요청 모달 (inline) -->
        <div id="shipment-request-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000; display:none; justify-content:center; align-items:center">
          <div style="background:var(--card); border-radius:12px; padding:24px; width:500px; max-width:90vw; max-height:80vh; overflow-y:auto">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px">
              <h3 style="margin:0; font-size:16px">발송 요청</h3>
              <button onclick="closeShipmentModal()" style="background:none; border:none; font-size:20px; cursor:pointer; color:var(--text3)">&times;</button>
            </div>
            <div id="shipment-modal-info" style="background:var(--bg2); padding:12px; border-radius:8px; margin-bottom:16px; font-size:13px"></div>
            <div class="form-row">
              <span class="form-label">협력사</span>
              <select id="ship-supplier" class="form-input" style="width:200px">
                <option value="">선택하세요</option>
              </select>
            </div>
            <div class="form-row">
              <span class="form-label">허브넷 HBL</span>
              <input type="text" id="ship-hbl" class="form-input" style="width:200px" placeholder="HBL 번호">
            </div>
            <div class="form-row">
              <span class="form-label">메모</span>
              <input type="text" id="ship-notes" class="form-input" style="width:300px" placeholder="요청 사항">
            </div>
            <div class="form-row">
              <span class="form-label">증거 이미지</span>
              <input type="file" id="ship-proof" accept="image/*" style="font-size:12px">
            </div>
            <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:16px">
              <button class="btn btn-outline" onclick="closeShipmentModal()">취소</button>
              <button class="btn btn-primary" onclick="submitShipmentRequest()">발송 요청</button>
            </div>
          </div>
        </div>

        <!-- 발송 진행 현황 -->
        <div class="card" style="margin-top:16px">
          <div class="card-title" style="display:flex; justify-content:space-between; align-items:center">
            <span><span class="icon">📦</span> 발송 진행 현황</span>
            <div style="display:flex; gap:8px; align-items:center">
              <select id="logi-filter-status" class="form-input" style="width:120px; font-size:12px" onchange="loadShipmentRequests()">
                <option value="">전체 상태</option>
                <option value="요청">요청</option>
                <option value="발송완료">발송완료</option>
                <option value="허브넷도착">허브넷도착</option>
                <option value="통관중">통관중</option>
                <option value="배송완료">배송완료</option>
              </select>
              <select id="logi-filter-supplier" class="form-input" style="width:120px; font-size:12px" onchange="loadShipmentRequests()">
                <option value="">전체 협력사</option>
              </select>
              <button class="btn btn-outline" onclick="loadShipmentRequests()" style="font-size:12px; padding:4px 12px">새로고침</button>
              <button class="btn btn-outline" onclick="exportShipments()" style="font-size:12px; padding:4px 12px">엑셀 내보내기</button>
            </div>
          </div>
          <div style="overflow-x:auto">
            <table>
              <thead>
                <tr>
                  <th>주문번호</th>
                  <th>상품</th>
                  <th>사이즈</th>
                  <th>협력사</th>
                  <th>HBL</th>
                  <th>요청일</th>
                  <th>트래킹</th>
                  <th>상태</th>
                  <th>증거</th>
                  <th>작업</th>
                </tr>
              </thead>
              <tbody id="logi-requests-tbody">
                <tr><td colspan="10" class="text-muted">로딩 중...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 트래킹 일괄 가져오기 -->
        <div class="card" style="margin-top:16px">
          <div class="card-title"><span class="icon">📥</span> 트래킹 번호 일괄 가져오기</div>
          <p class="text-muted" style="font-size:12px; margin-bottom:8px">
            협력사가 전달한 엑셀 파일에서 트래킹 번호를 일괄 입력합니다. (열: 주문번호 또는 HBL, 트래킹번호)
          </p>
          <div style="display:flex; gap:12px; align-items:center">
            <input type="file" id="tracking-import-file" accept=".csv,.xlsx,.xls" style="font-size:12px">
            <button class="btn btn-primary" onclick="importTracking()">가져오기</button>
            <span id="tracking-import-status" style="font-size:12px; color:var(--text2)"></span>
          </div>
        </div>

        <div class="divider"></div>

        <!-- 협력사 관리 -->
        <div class="card">
          <div class="card-title" style="display:flex; justify-content:space-between; align-items:center">
            <span><span class="icon">🤝</span> 협력사 관리</span>
            <button class="btn btn-outline" onclick="loadSuppliers()" style="font-size:12px; padding:4px 12px">새로고침</button>
          </div>
          <!-- 협력사 추가 폼 -->
          <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:flex-end; margin-bottom:12px; padding:12px; background:var(--bg2); border-radius:8px">
            <div>
              <label style="font-size:11px; color:var(--text3); display:block; margin-bottom:2px">이름 *</label>
              <input type="text" id="sup-name" class="form-input" style="width:120px" placeholder="협력사명">
            </div>
            <div>
              <label style="font-size:11px; color:var(--text3); display:block; margin-bottom:2px">담당자</label>
              <input type="text" id="sup-contact" class="form-input" style="width:100px" placeholder="담당자명">
            </div>
            <div>
              <label style="font-size:11px; color:var(--text3); display:block; margin-bottom:2px">전화번호</label>
              <input type="text" id="sup-phone" class="form-input" style="width:130px" placeholder="010-0000-0000">
            </div>
            <div>
              <label style="font-size:11px; color:var(--text3); display:block; margin-bottom:2px">WeChat</label>
              <input type="text" id="sup-wechat" class="form-input" style="width:120px" placeholder="WeChat ID">
            </div>
            <div>
              <label style="font-size:11px; color:var(--text3); display:block; margin-bottom:2px">메모</label>
              <input type="text" id="sup-notes" class="form-input" style="width:150px" placeholder="비고">
            </div>
            <button class="btn btn-primary" onclick="addSupplier()">추가</button>
          </div>
          <div style="overflow-x:auto">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>이름</th>
                  <th>담당자</th>
                  <th>전화번호</th>
                  <th>WeChat</th>
                  <th>메모</th>
                  <th>등록일</th>
                  <th>작업</th>
                </tr>
              </thead>
              <tbody id="sup-tbody">
                <tr><td colspan="8" class="text-muted">로딩 중...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
